# ClaudeMeter website - required environment variables.
# Copy to .env.local for dev. For production, set these in Cloud Run.

# PostHog - public, injected at build time by Docker and Cloud Run env.
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Neon - pooled connection string. Use the "pooled" endpoint, not direct.
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/claude_meter?sslmode=require

# Resend - transactional email.
RESEND_API_KEY=re_xxx
